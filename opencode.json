{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.local": "deny",
      "*.env.production": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "ask",
      "*.env": "deny",
      "*.env.local": "deny",
      "*.env.production": "deny",
      "*.pem": "deny",
      "*.key": "deny"
    },
    "bash": {
      "*": "ask",

      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "which *": "allow",
      "whoami": "allow",
      "find *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "wc *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "du *": "allow",
      "df *": "allow",
      "env": "allow",
      "date": "allow",

      "git status": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git diff": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git branch": "allow",
      "git remote *": "allow",
      "git fetch *": "allow",
      "git fetch": "allow",
      "git stash list": "allow",
      "git tag *": "allow",
      "git blame *": "allow",

      "git add *": "allow",
      "git commit *": "allow",
      "git checkout *": "allow",
      "git switch *": "allow",
      "git restore *": "allow",
      "git merge *": "allow",
      "git rebase *": "allow",
      "git cherry-pick *": "allow",
      "git stash *": "allow",

      "git push *": "ask",
      "git push": "ask",
      "git pull *": "ask",
      "git pull": "ask",
      "git reset --hard *": "ask",
      "git clean *": "ask",

      "gh repo view *": "allow",
      "gh repo clone *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh issue create *": "ask",
      "gh issue edit *": "ask",
      "gh issue close *": "ask",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr checks *": "allow",
      "gh pr create *": "ask",
      "gh pr merge *": "ask",
      "gh pr review *": "ask",
      "gh workflow list *": "allow",
      "gh workflow view *": "allow",
      "gh workflow run *": "ask",
      "gh release list *": "allow",
      "gh release view *": "allow",
      "gh release create *": "ask",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh run watch *": "allow",
      "gh api *": "ask",

      "openspec *": "allow",
      "opencode *": "allow",

      "rm -rf *": "deny",
      "rm -r *": "deny",
      "rmdir *": "deny",
      "chmod *": "deny",
      "chown *": "deny",
      "sudo *": "deny",
      "curl * | *": "deny",
      "wget * | *": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "*": "ask"
    }
  }
}
